{
  "version": 2,
  "framework": null,
  "installCommand": "npm install",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "crons": [
    {
      "path": "/api/cron/permit-sync",
      "schedule": "0 0 * * *"
    }
  ]
}
